<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<title>मोबाइल रिपेयर शॉप प्रो</title>
<style>
body {
    margin:0;
    font-family: Arial;
    background: url('https://images.unsplash.com/photo-1581090700227-78d84487c305?auto=format&fit=crop&w=1200&q=80') no-repeat center center fixed;
    background-size: cover;
    color: #fff;
    text-align: center;
}
#topbar {
    background: rgba(0,0,0,0.7);
    padding: 10px;
    font-size: 16px;
}
#shop {
    margin: 20px auto;
    width: 260px;
    height: 470px;
    background: rgba(0,0,0,0.6);
    border: 5px solid #444;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
}
#phone {
    width: 180px;
    height: 320px;
    margin: 20px auto;
    border-radius: 20px;
    border: 4px solid #888;
    transition: transform 0.3s, background 0.5s;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
}
#customer {
    width: 80px;
    height: 80px;
    position: absolute;
    top: 10px;
    left: -100px;
    background: url('https://cdn-icons-png.flaticon.com/512/2922/2922506.png') no-repeat center;
    background-size: contain;
    transition: left 2s linear;
}
button {
    padding: 10px 15px;
    margin: 5px;
    font-size: 14px;
    border:none;
    border-radius: 8px;
    cursor:pointer;
    background:#2563eb;
    color:white;
}
button:hover { background:#1d4ed8; }
#status { margin-top: 10px; font-size: 16px; }
#extras { margin-top: 15px; }
#levelup { font-size: 18px; margin: 10px; color: #ff0; animation: glow 1s infinite alternate; }
@keyframes glow { from{ text-shadow:0 0 5px #ff0; } to{ text-shadow:0 0 20px #ff0; } }
</style>
</head>
<body>

<h1>📱 मोबाइल रिपेयर शॉप प्रो</h1>

<div id="topbar">
⭐ लेवल: <span id="level">1</span> | ❤️ लाइफ्स: <span id="lives">5</span> | 💰 कॉइन्स: <span id="coins">0</span>
</div>

<div id="shop">
    <div id="customer"></div>
    <div id="phone"></div>
</div>

<h2 id="problem">समस्या: स्क्रीन टूटी हुई</h2>
<div id="levelup"></div>

<div id="tools">
    <button onclick="repair('screw')">🔩 स्क्रू खोलें</button>
    <button onclick="repair('charging')">🔥 चार्जिंग पिन सोल्डर करें</button>
    <button onclick="repair('screen')">📱 ग्लास बदलें</button>
    <button onclick="repair('battery')">🔋 बैटरी बदलें</button>
</div>

<div id="status"></div>

<div id="extras">
    <button onclick="buyLives()">❤️ लाइफ्स खरीदें (50 कॉइन्स)</button>
</div>

<audio id="repairSound" src="https://www.soundjay.com/buttons/sounds/button-09.mp3"></audio>
<audio id="customerSound" src="https://www.soundjay.com/human/sounds/crowd-01.mp3"></audio>
<audio id="bgMusic" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" loop autoplay></audio>

<script>
let level = 1;
let coins = 0;
let lives = 5;
let problems = ["screen","battery","charging"];
let mobiles = [
    "https://upload.wikimedia.org/wikipedia/commons/thumb/f/fb/IPhone_13_Pro_Max_Pacific_Blue.png/220px-IPhone_13_Pro_Max_Pacific_Blue.png",
    "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3e/Samsung_Galaxy_S21.png/220px-Samsung_Galaxy_S21.png",
    "https://upload.wikimedia.org/wikipedia/commons/thumb/5/57/Realme_8_Pro.png/220px-Realme_8_Pro.png",
    "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3d/Google_Pixel_6.png/220px-Google_Pixel_6.png"
];
let problem = problems[Math.floor(Math.random()*3)];

updateUI();
spawnCustomer();
changeMobile();

function updateUI(){
    document.getElementById("level").innerText = level;
    document.getElementById("coins").innerText = coins;
    document.getElementById("lives").innerText = lives;
}

function playSound(id){ document.getElementById(id).play(); }

function animatePhone(){
    let phone=document.getElementById("phone");
    phone.style.transform = "rotate(5deg) scale(1.05)";
    setTimeout(()=>{ phone.style.transform = "rotate(0deg) scale(1)"; },300);
}

function spawnCustomer(){
    let cust = document.getElementById("customer");
    cust.style.left = "-100px";
    playSound('customerSound');
    setTimeout(()=>{ cust.style.left = "10px"; },100);
}

function changeMobile(){
    let phoneImg = document.getElementById("phone");
    let newMobile = mobiles[Math.floor(Math.random()*mobiles.length)];
    phoneImg.style.background = `url(${newMobile}) no-repeat center`;
}

function repair(tool){
    animatePhone();
    playSound('repairSound');
    if(tool==problem){
        coins += 20;
        document.getElementById("status").innerText = "✅ फोन ठीक हो गया! +20 कॉइन्स";
        levelUp();
        nextLevel();
    } else {
        lives--;
        document.getElementById("status").innerText = "❌ गलत रिपेयर";
        if(lives<=0){ gameOver(); }
    }
    updateUI();
}

function levelUp(){
    let lvlText = document.getElementById("levelup");
    lvlText.innerText = "🎉 लेवल अप! 🎉";
    setTimeout(()=>{ lvlText.innerText = ""; },2000);
}

function nextLevel(){
    level++;
    problem = problems[Math.floor(Math.random()*3)];
    let problemsText=["स्क्रीन टूटी हुई","बैटरी खत्म","चार्जिंग पिन खराब"];
    document.getElementById("problem").innerText="लेवल "+level+" : "+problemsText[Math.floor(Math.random()*3)];
    spawnCustomer();
    changeMobile();
}

function gameOver(){
    document.getElementById("status").innerText="❌ लाइफ्स खत्म! 1 घंटे या खरीदकर रिस्टोर करें";
    setTimeout(()=>{ lives=5; updateUI(); document.getElementById("status").innerText="❤️ लाइफ्स रिस्टोर हो गई!"; },3600000);
}

function buyLives(){
    if(coins>=50){
        coins -=50; lives=5;
        document.getElementById("status").innerText="❤️ लाइफ्स खरीदी गई";
    } else {
        document.getElementById("status").innerText="50 कॉइन्स चाहिए";
    }
    updateUI();
}
</script>
</body>
</html>
